# Generated local runtime configuration.
# Keep this file private. Do not commit real secrets or tunnel URLs.

# =============================================================================
# General
# =============================================================================
DOMAIN=example.ngrok-free.dev
TZ=America/Sao_Paulo

# =============================================================================
# Proxy / Network
# =============================================================================
WARP_PROXY=

# =============================================================================
# Images
# =============================================================================
GITHUB_UNIFIED_MCP_IMAGE=ghcr.io/vinicius-ssantos/github-unified-mcp:main
DEPLOY_ORCHESTRATOR_MCP_IMAGE=ghcr.io/vinicius-ssantos/deploy-orchestrator-mcp:main
MCP_SOCIAL_IMAGE=ghcr.io/vinicius-ssantos/mcp-social:main
GITHUB_UNIFIED_MCP_BFF_IMAGE=ghcr.io/vinicius-ssantos/github-unified-mcp-bff:main
VOS_STUDIO_MCP_IMAGE=ghcr.io/vinicius-ssantos/vos-studio-mcp:main
VOS_STUDIO_BFF_IMAGE=ghcr.io/vinicius-ssantos/vos-studio-bff:main
CENTRAL_MCP_GATEWAY_IMAGE=ghcr.io/vinicius-ssantos/central-mcp-gateway:main
REPO_RESEARCH_SIDECAR_IMAGE=ghcr.io/vinicius-ssantos/repo-research-mcp:main
JOB_HUNTER_IMAGE=ghcr.io/vinicius-ssantos/jobhunteragent:main
WORKFLOW_ENGINE_IMAGE=ghcr.io/vinicius-ssantos/workflow-engine:main

# =============================================================================
# github-unified-mcp
# =============================================================================
# Token
GITHUB_TOKEN=change-me
# Auth
MCP_AUTH_ENABLED=true
# Repo scope
GITHUB_ALLOWED_REPOS=vinicius-ssantos/github-unified-mcp,vinicius-ssantos/deploy-orchestrator-mcp,vinicius-ssantos/personal-platform-infra,vinicius-ssantos/mcp-social,vinicius-ssantos/github-unified-mcp-bff,vinicius-ssantos/vos-studio-mcp,vinicius-ssantos/vos-studio-bff,vinicius-ssantos/central-mcp-gateway,vinicius-ssantos/mcp-code-sandbox
GITHUB_READ_ONLY=false
GITHUB_ENABLE_DANGEROUS_TOOLS=true
GITHUB_REQUIRE_ALLOWED_REPOS=true
# Public URL
GITHUB_MCP_PUBLIC_URL=https://example.ngrok-free.dev/github-mcp

# =============================================================================
# deploy-orchestrator-mcp
# =============================================================================
# Token
MCP_SERVER_API_KEY=change-me
# Config
MCP_READ_ONLY=true
MCP_REQUIRE_CONFIRMATION=true
# Public URL
DEPLOY_MCP_PUBLIC_URL=https://example.ngrok-free.dev/deploy-mcp

# =============================================================================
# mcp-social
# =============================================================================
# Token
SOCIAL_MCP_ACCESS_TOKEN=change-me
# Config
SOCIAL_DB_URL=sqlite+aiosqlite:////data/social.db
# Public URL
SOCIAL_MCP_PUBLIC_URL=https://example.ngrok-free.dev/social-mcp

# =============================================================================
# github-unified-mcp-bff
# =============================================================================
# Config
BFF_ENV=development
GITHUB_BFF_FRONTEND_URL=http://localhost:5173
GITHUB_BFF_ALLOWED_ORIGINS=http://localhost:5173
COOKIE_SECURE=false
# Public URL
GITHUB_BFF_PUBLIC_URL=https://example.ngrok-free.dev/github-bff

# =============================================================================
# vos-studio-mcp
# =============================================================================
# Database
DATABASE_URL=postgresql+asyncpg://postgres:change-me@host:5432/postgres
# Storage (R2)
STORAGE_PROVIDER=r2
STORAGE_ENDPOINT=https://account-id.r2.cloudflarestorage.com
STORAGE_BUCKET=vos-studio-assets
STORAGE_ACCESS_KEY=change-me
STORAGE_SECRET_KEY=change-me
STORAGE_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# Celery / Redis
VOS_REDIS_URL=redis://redis:6379/1
VOS_CELERY_BROKER_URL=redis://redis:6379/1
VOS_CELERY_RESULT_BACKEND=redis://redis:6379/1
# Social MCP integration
SOCIAL_MCP_ENABLED=true
SOCIAL_MCP_URL=http://mcp-social:8080/mcp/
# Env
APP_ENV=development
# Public URL
VOS_MCP_PUBLIC_URL=https://example.ngrok-free.dev/vos-mcp

# =============================================================================
# vos-studio-bff
# =============================================================================
VOS_BFF_FRONTEND_URL=http://localhost:5174
VOS_BFF_ALLOWED_ORIGINS=http://localhost:5174
# Public URL
VOS_BFF_PUBLIC_URL=https://example.ngrok-free.dev/vos-bff

# =============================================================================
# central-mcp-gateway
# =============================================================================
# Tokens / Secrets
MCP_BEARER_TOKEN=change-me
CENTRAL_MCP_GATEWAY_PUBLIC_BEARER_TOKEN=change-me
CENTRAL_MCP_GATEWAY_OAUTH_CLIENT_SECRET=
CENTRAL_MCP_GATEWAY_SESSION_SECRET=change-me
CENTRAL_MCP_GATEWAY_ADMIN_TOKEN=change-me
GATEWAY_CONFIRM_TELEGRAM_TOKEN=
GATEWAY_CONFIRM_TELEGRAM_CHAT_ID=
# Redis
GATEWAY_REDIS_URL=redis://redis:6379/0
# OAuth
GATEWAY_OAUTH_CLIENT_ID=chatgpt
GATEWAY_OAUTH_DEFAULT_SCOPES="gateway:read github:read github:write deploy:read social:write sandbox:run repo:read repo-research:read vos:read vos:write"
CENTRAL_MCP_GATEWAY_OAUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000/oauth/callback,https://chat.openai.com/aip/oauth/callback
# Owner mode (DEV only)
GATEWAY_OWNER_MODE_ENABLED=true
GATEWAY_OWNER_CLIENT_IDS=chatgpt
GATEWAY_OWNER_ALLOW_DYNAMIC_WRITES=true
GATEWAY_OWNER_ALLOW_EXTERNAL_PUBLICATION=true
GATEWAY_OWNER_ALLOW_DESTRUCTIVE=true
GATEWAY_OWNER_DRY_RUN=false
GATEWAY_OWNER_BEARER_TOKEN=
# Config
GATEWAY_ENVIRONMENT=local
GATEWAY_LOG_LEVEL=info
GATEWAY_RATE_LIMIT_PER_TOOL_PER_MINUTE=20
GATEWAY_TRUSTED_PROXY_COUNT=1
GATEWAY_IDEMPOTENCY_TTL_SECONDS=300
GATEWAY_ALLOW_PRIVATE_UPSTREAM_URLS=true
GATEWAY_CONFIRM_CHANNEL=none
# Admin
CENTRAL_MCP_GATEWAY_ADMIN_ENABLED=true
CENTRAL_MCP_GATEWAY_ADMIN_UI_ENABLED=true
CENTRAL_MCP_GATEWAY_DYNAMIC_UPSTREAMS_ENABLED=true
# Public URL
CENTRAL_MCP_GATEWAY_PUBLIC_URL=https://example.ngrok-free.dev

# =============================================================================
# mcp-code-sandbox
# =============================================================================
# Token
SANDBOX_API_KEY=change-me
# Config
SANDBOX_LOG_LEVEL=INFO
SANDBOX_MAX_OUTPUT_BYTES=1048576
SANDBOX_MAX_PROJECT_FILES=64
SANDBOX_MAX_PROJECT_BYTES=8388608
SANDBOX_MAX_ENV_VARS=32
SANDBOX_MAX_OUTPUT_FILES=16
SANDBOX_MAX_CONCURRENT=4
SANDBOX_QUEUE_TIMEOUT_SECONDS=30
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_PERIOD=100000
SANDBOX_CPU_QUOTA=50000
SANDBOX_PIDS_LIMIT=128
# Local dev path
MCP_CODE_SANDBOX_REPO_PATH=
# Gateways upstream
GATEWAY_UPSTREAM_SANDBOX_URL=http://mcp-code-sandbox:8766/mcp

# =============================================================================
# repo-research-sidecar
# =============================================================================
# Tokens
REPO_RESEARCH_SIDECAR_API_KEY=change-me
REPO_RESEARCH_GITHUB_TOKEN=change-me
# Config
REPO_RESEARCH_MAX_FETCH_BYTES=100000
REPO_RESEARCH_CACHE_TTL_SECONDS=300
REPO_RESEARCH_ALLOWED_REPOSITORIES=["vinicius-ssantos/repo-research-mcp"]

# =============================================================================
# workflow-engine
# =============================================================================
# Config
WORKFLOW_ENGINE_KAFKA_BOOTSTRAP_SERVERS=
# Postgres (local compose)
POSTGRES_DB=workflow_engine
POSTGRES_USER=workflow
POSTGRES_PASSWORD=workflow

# =============================================================================
# job-hunter-agent
# =============================================================================
JOB_HUNTER_TELEGRAM_TOKEN=
JOB_HUNTER_TELEGRAM_CHAT_ID=
JOB_HUNTER_OLLAMA_URL=http://ollama:11434
JOB_HUNTER_CANDIDATE_PROFILE_PATH=./config/candidate_profile.json
JOB_HUNTER_COLLECTION_TIME=08:00
JOB_HUNTER_BROWSER_HEADLESS=true
JOB_HUNTER_CONFIG_PATH=./config/job-hunter

# =============================================================================
# Ngrok
# =============================================================================
NGROK_STATIC_DOMAIN=example.ngrok-free.dev
NGROK_PUBLIC_URL=https://example.ngrok-free.dev
PUBLIC_EDGE_TOKEN=change-me

# =============================================================================
# Tailscale
# =============================================================================
# Host Funnel
TAILSCALE_FUNNEL_PUBLIC_URL=
TAILSCALE_FUNNEL_HTTPS_PORT=443
# Container Funnel
TAILSCALE_AUTHKEY=
TAILSCALE_CONTAINER_HOSTNAME=personal-platform-gateway
TAILSCALE_CONTAINER_PUBLIC_URL=
TAILSCALE_CONTAINER_HTTPS_PORT=443

# =============================================================================
# Other
# =============================================================================
OPENROUTER_API_KEY=change-me
