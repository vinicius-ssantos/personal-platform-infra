{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 9am on monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all platform service images into a single PR",
      "matchPackagePatterns": ["ghcr.io/vinicius-ssantos/.*"],
      "groupName": "platform images",
      "automerge": false
    },
    {
      "description": "Auto-merge patch-level GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ],
  "docker": {
    "enabled": true
  },
  "kubernetes": {
    "enabled": true,
    "fileMatch": ["k8s/.*\\.yaml$"]
  }
}
