{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "docker:pinDigests"],
  "schedule": ["before 9am on monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all platform service images into a single PR",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^ghcr\\.io/vinicius-ssantos//"],
      "groupName": "platform images",
      "automerge": false
    },
    {
      "description": "Auto-merge patch-level GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track ghcr image tags declared in .env.example",
      "managerFilePatterns": ["/^\\.env\\.example$/"],
      "matchStrings": [
        "=(?<depName>ghcr\\.io/[^:\\s]+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "kubernetes": {
    "enabled": true,
    "managerFilePatterns": ["/k8s/.*\\.yaml$/"]
  }
}
