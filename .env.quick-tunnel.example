# Quick Tunnel local runtime example
#
# Use this only for account-less Cloudflare Quick Tunnels created with:
#   cloudflared tunnel --url http://localhost:<port>
#
# These URLs are temporary and change whenever the tunnel process is recreated.

# General
DOMAIN=trycloudflare.com
TZ=America/Sao_Paulo

# Images
GITHUB_UNIFIED_MCP_IMAGE=ghcr.io/vinicius-ssantos/github-unified-mcp:main
DEPLOY_ORCHESTRATOR_MCP_IMAGE=ghcr.io/vinicius-ssantos/deploy-orchestrator-mcp:main
MCP_SOCIAL_IMAGE=ghcr.io/vinicius-ssantos/mcp-social:main
GITHUB_UNIFIED_MCP_BFF_IMAGE=ghcr.io/vinicius-ssantos/github-unified-mcp-bff:main
VOS_STUDIO_MCP_IMAGE=ghcr.io/vinicius-ssantos/vos-studio-mcp:main
VOS_STUDIO_BFF_IMAGE=ghcr.io/vinicius-ssantos/vos-studio-bff:main
CENTRAL_MCP_GATEWAY_IMAGE=ghcr.io/vinicius-ssantos/central-mcp-gateway:main

# Ngrok public edge (optional alternative to Cloudflare Quick Tunnel)
# Set this to your reserved ngrok static domain, for example:
# NGROK_STATIC_DOMAIN=your-domain.ngrok-free.app
NGROK_STATIC_DOMAIN=
NGROK_PUBLIC_URL=
TAILSCALE_FUNNEL_PUBLIC_URL=
TAILSCALE_FUNNEL_HTTPS_PORT=443

# Temporary public URLs from cloudflared quick tunnels
GITHUB_MCP_PUBLIC_URL=https://replace-with-generated-url.trycloudflare.com
DEPLOY_MCP_PUBLIC_URL=https://replace-with-generated-url.trycloudflare.com
SOCIAL_MCP_PUBLIC_URL=https://replace-with-generated-url.trycloudflare.com
GITHUB_BFF_PUBLIC_URL=https://replace-with-generated-url.trycloudflare.com
VOS_MCP_PUBLIC_URL=https://replace-with-generated-url.trycloudflare.com
VOS_BFF_PUBLIC_URL=https://replace-with-generated-url.trycloudflare.com
CENTRAL_MCP_GATEWAY_PUBLIC_URL=https://replace-with-generated-url.trycloudflare.com

# Secrets: do not put real values in committed files
GITHUB_TOKEN=change-me
MCP_BEARER_TOKEN=change-me
MCP_SERVER_API_KEY=change-me
SOCIAL_MCP_ACCESS_TOKEN=change-me
PUBLIC_EDGE_TOKEN=change-me
CENTRAL_MCP_GATEWAY_PUBLIC_BEARER_TOKEN=change-me
CENTRAL_MCP_GATEWAY_OAUTH_CLIENT_SECRET=change-me
CENTRAL_MCP_GATEWAY_SESSION_SECRET=change-me
CENTRAL_MCP_GATEWAY_OAUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000/oauth/callback,https://chat.openai.com/aip/oauth/callback
