# Fake/non-production environment for the `safe-test` and `mock` sandbox
# profiles (.sandbox/manifest.yaml). Copy to .sandbox/env.safe to use locally
# — that file is gitignored, this example is the committed template.
#
# Every value here is a placeholder. The safe-test profile never reads real
# GITHUB_TOKEN, kubeconfig, Terraform vars, or VPS secrets — see
# docs/repo-sandbox-security.md ("Secrets policy"). Manifest loading is
# expected to reject any *_TOKEN/*_KEY/*_SECRET/*_PASSWORD key carrying a
# non-empty literal value once the runner (#221) enforces that check; this
# file exists so there is nothing real to leak even before that enforcement
# lands.

SANDBOX_PROFILE=safe-test
GITHUB_TOKEN=fake-not-a-real-token
MCP_BEARER_TOKEN=fake-not-a-real-token
