cloudflare_account_id = "change-me"
cloudflare_zone_id    = "change-me"
domain                = "example.com"
target_mode           = "local-tunnel"
vps_ipv4              = null

cloudflare_access_enabled               = false
cloudflare_access_allowed_emails        = ["you@example.com"]
cloudflare_access_allowed_email_domains = []
cloudflare_access_allowed_idps          = []
cloudflare_access_service_token_enabled = false

# Sensitive — set via environment variable instead of committing here:
#   export TF_VAR_cloudflare_api_token="your-token"
#   export TF_VAR_tunnel_secret="$(openssl rand -hex 32 | base64)"
