# Template for VPS runtime secrets.
#
# OPTION A — imperative (quickest):
#   kubectl create secret generic platform-secrets -n mcp \
#     --from-literal=GITHUB_TOKEN=<token> \
#     --from-literal=MCP_BEARER_TOKEN=<token> \
#     --from-literal=MCP_SERVER_API_KEY=<key> \
#     --from-literal=SOCIAL_MCP_ACCESS_TOKEN=<token>
#
#   kubectl create secret generic platform-secrets -n bff \
#     --from-literal=MCP_TOKEN=<token>
#
#   kubectl create secret generic platform-secrets -n vos \
#     --from-literal=PLACEHOLDER=none
#
# OPTION B — SOPS (recommended once age keys are configured, see docs/secrets.md):
#   cp platform-secrets-vps.yaml.example platform-secrets-vps.yaml
#   # fill in real values below
#   sops --encrypt --in-place platform-secrets-vps.yaml
#   # add platform-secrets-vps.yaml to kustomization.yaml resources
#   # add SOPS_AGE_KEY secret to GitHub Actions
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-secrets
  namespace: mcp
type: Opaque
stringData:
  GITHUB_TOKEN: change-me
  MCP_BEARER_TOKEN: change-me
  MCP_SERVER_API_KEY: change-me
  SOCIAL_MCP_ACCESS_TOKEN: change-me
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-secrets
  namespace: bff
type: Opaque
stringData:
  MCP_TOKEN: change-me
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-secrets
  namespace: vos
type: Opaque
stringData:
  PLACEHOLDER: none
