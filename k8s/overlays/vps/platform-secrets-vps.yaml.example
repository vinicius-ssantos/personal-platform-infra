# Template for VPS runtime secrets.
#
# OPTION A — imperative (quickest):
#   kubectl create secret generic platform-secrets -n mcp \
#     --from-literal=GITHUB_TOKEN=<token> \
#     --from-literal=MCP_BEARER_TOKEN=<token> \
#     --from-literal=MCP_SERVER_API_KEY=<key> \
#     --from-literal=SOCIAL_MCP_ACCESS_TOKEN=<token> \
#     --from-literal=REPO_RESEARCH_SIDECAR_API_KEY=<openssl-rand-hex-32> \
#     --from-literal=REPO_RESEARCH_GITHUB_TOKEN=<github-pat> \
#     --from-literal=REPO_RESEARCH_ALLOWED_REPOSITORIES='["owner/repo"]'
#
#   kubectl create secret generic platform-secrets -n bff \
#     --from-literal=MCP_TOKEN=<token>
#
#
#   kubectl create secret generic platform-secrets -n vos \
#     --from-literal=DATABASE_URL=<postgres-url> \
#     --from-literal=STORAGE_ENDPOINT=<r2-endpoint> \
#     --from-literal=STORAGE_BUCKET=<bucket-name> \
#     --from-literal=STORAGE_ACCESS_KEY=<access-key> \
#     --from-literal=STORAGE_SECRET_KEY=<secret-key> \
#     --from-literal=STORAGE_PUBLIC_BASE_URL=<public-url> \
#     --from-literal=SOCIAL_MCP_ENABLED=true \
#     --from-literal=SOCIAL_MCP_URL=<social-mcp-url> \
#     --from-literal=SOCIAL_MCP_ACCESS_TOKEN=<token> \
#     --from-literal=VOS_REDIS_URL=<redis-url> \
#     --from-literal=VOS_CELERY_BROKER_URL=<redis-url> \
#     --from-literal=VOS_CELERY_RESULT_BACKEND=<redis-url>
#
#   ADDITIONAL — workflow-engine (deployment in namespace mcp):
#   kubectl create secret generic platform-secrets -n mcp \
#     --from-literal=WORKFLOW_ENGINE_DATABASE_URL=<jdbc-url> \
#     --from-literal=WORKFLOW_ENGINE_DATABASE_USERNAME=<user> \
#     --from-literal=WORKFLOW_ENGINE_DATABASE_PASSWORD=<password> \
#     --from-literal=WORKFLOW_ENGINE_REDIS_URL=<redis-url> \
#     --from-literal=WORKFLOW_ENGINE_KAFKA_BOOTSTRAP_SERVERS=<kafka-bootstrap-servers>
#
# OPTION B — SOPS, declarative (recommended once age keys are configured):
#   The encrypted manifests live at secrets/platform-secrets-vps.enc.yaml (gitignored)
#   and are applied with a dedicated decrypt step — NOT via kustomize, because plain
#   `kubectl apply -k` cannot decrypt SOPS. See docs/secrets.md and:
#     secrets/platform-secrets-vps.enc.yaml.example   (template)
#     just secrets-edit-vps-k8s                        (edit encrypted)
#     just k8s-vps-secrets                             (decrypt + apply to cluster)
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-secrets
  namespace: mcp
type: Opaque
stringData:
  GITHUB_TOKEN: change-me
  MCP_BEARER_TOKEN: change-me
  MCP_SERVER_API_KEY: change-me
  SOCIAL_MCP_ACCESS_TOKEN: change-me
  REPO_RESEARCH_SIDECAR_API_KEY: change-me
  REPO_RESEARCH_GITHUB_TOKEN: change-me
  REPO_RESEARCH_ALLOWED_REPOSITORIES: '["vinicius-ssantos/repo-research-mcp", "vinicius-ssantos/WorkflowEngine"]'
  WORKFLOW_ENGINE_DATABASE_URL: change-me
  WORKFLOW_ENGINE_DATABASE_USERNAME: change-me
  WORKFLOW_ENGINE_DATABASE_PASSWORD: change-me
  WORKFLOW_ENGINE_REDIS_URL: change-me
  WORKFLOW_ENGINE_KAFKA_BOOTSTRAP_SERVERS: change-me
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-secrets
  namespace: bff
type: Opaque
stringData:
  MCP_TOKEN: change-me
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-secrets
  namespace: vos
type: Opaque
stringData:
  DATABASE_URL: change-me
  STORAGE_ENDPOINT: change-me
  STORAGE_BUCKET: change-me
  STORAGE_ACCESS_KEY: change-me
  STORAGE_SECRET_KEY: change-me
  STORAGE_PUBLIC_BASE_URL: change-me
  SOCIAL_MCP_ENABLED: "true"
  SOCIAL_MCP_URL: change-me
  SOCIAL_MCP_ACCESS_TOKEN: change-me
  VOS_REDIS_URL: change-me
  VOS_CELERY_BROKER_URL: change-me
  VOS_CELERY_RESULT_BACKEND: change-me
