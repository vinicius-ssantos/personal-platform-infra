# Template for the VPS runtime platform-secrets, managed declaratively with SOPS.
#
# Setup (once age keys are configured, see docs/secrets.md):
#   cp secrets/platform-secrets-vps.enc.yaml.example secrets/platform-secrets-vps.enc.yaml
#   # fill in real values below, then encrypt in place:
#   SOPS_AGE_KEY_FILE=~/.age/personal-platform.txt sops -e -i secrets/platform-secrets-vps.enc.yaml
#   # edit later with: just secrets-edit-vps-k8s
#
# Apply to the VPS cluster (from a machine with the age key + VPS kubeconfig):
#   just k8s-vps-secrets        # = sops --decrypt ... | kubectl apply -f -
#
# The encrypted file (secrets/platform-secrets-vps.enc.yaml) is gitignored and is
# NOT consumed by the kustomize overlay — plain `kubectl apply -k` cannot decrypt
# SOPS. Apply it as a separate step before/independently of the manifest rollout;
# the deployments reference these Secrets by name.
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-secrets
  namespace: mcp
type: Opaque
stringData:
  GITHUB_TOKEN: change-me
  MCP_BEARER_TOKEN: change-me
  MCP_SERVER_API_KEY: change-me
  SOCIAL_MCP_ACCESS_TOKEN: change-me
  REPO_RESEARCH_SIDECAR_API_KEY: change-me
  REPO_RESEARCH_GITHUB_TOKEN: change-me
  REPO_RESEARCH_ALLOWED_REPOSITORIES: '["vinicius-ssantos/repo-research-mcp"]'
  # R2 credentials for the mcp-social-backup CronJob (see k8s/base/apps/mcp-social/backup-cronjob.yaml)
  R2_ENDPOINT: change-me
  R2_BUCKET: change-me
  R2_ACCESS_KEY_ID: change-me
  R2_SECRET_ACCESS_KEY: change-me
  # Optional dead-man's-switch pings (healthchecks.io check URLs). The backup
  # and restore-verify CronJobs ping these on success; a missed ping raises an
  # external alert even when the cluster itself is down. Omit the keys (or
  # leave the Secret without them — they are optional:true) to disable.
  HEALTHCHECKS_BACKUP_URL: change-me
  HEALTHCHECKS_RESTORE_URL: change-me
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-secrets
  namespace: bff
type: Opaque
stringData:
  MCP_TOKEN: change-me
---
apiVersion: v1
kind: Secret
metadata:
  name: platform-secrets
  namespace: vos
type: Opaque
stringData:
  PLACEHOLDER: none
---
# Grafana admin credentials. The grafana Deployment reads admin-user/admin-password
# from this Secret via secretKeyRef; it must exist before monitoring is scaled up.
# (Locally, `just grafana-secret` creates the same Secret imperatively.)
apiVersion: v1
kind: Secret
metadata:
  name: grafana-admin
  namespace: monitoring
type: Opaque
stringData:
  admin-user: admin
  admin-password: change-me
---
# Telegram alerting credentials for Grafana. The grafana Deployment reads
# telegram-bot-token/telegram-chat-id via secretKeyRef (optional: true), and the
# provisioned contact point expands them with $__env{}. Create a bot via
# @BotFather for the token; get the chat id by messaging the bot then calling
# https://api.telegram.org/bot<TOKEN>/getUpdates. Without this Secret, alerting
# is provisioned but inert (no delivery).
apiVersion: v1
kind: Secret
metadata:
  name: grafana-alerting
  namespace: monitoring
type: Opaque
stringData:
  telegram-bot-token: change-me
  telegram-chat-id: change-me
